# ─────────────────────────────────────────────────────────────────────────────
# Kairos — plantilla de variables de entorno.
# Copia a `.env` y rellena los valores. NUNCA commitees `.env` con secretos reales.
# Las variables vacías son obligatorias antes de arrancar; las comentadas son opcionales.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Modo de ejecución del trading: sim | testnet | live
#   sim     = llena órdenes contra datos reales de prod SIN tocar el exchange (default seguro)
#   testnet = API sandbox de Binance (claves de testnet)
#   live    = DINERO REAL — no usar hasta validar en sim y testnet
KAIROS_MODE=sim

# Kill-switch global de emergencia: NO es una env var. Vive en Postgres (`kairos.bot_state.paused`)
# y se controla por WhatsApp con `/pausa` / `/reanuda` (SP11). Pausa el scanner Y bloquea los jobs
# ya encolados en `evaluateCandidate`.

# ── Modelos LLM (Flue / catálogo de proveedores de Pi) ───────────────────────
ANTHROPIC_API_KEY=
# Opcional: proveedor secundario para failover de modelo (ver ARCHITECTURE.md §9)
# OPENAI_API_KEY=

# Palancas de modelo por rol (§9 / ARCHITECTURE.md). Los defaults funcionan sin la variable;
# aquí se documenta la palanca para ajustar costo/calidad sin cambiar código.
DECISION_MODEL=                    # default anthropic/claude-sonnet-4-6
ESCALATION_MODEL=                  # default anthropic/claude-opus-4-6 (confirmar id en flue dev)
TECHNICAL_MODEL=                   # default anthropic/claude-haiku-4-5
FUNDAMENTAL_MODEL=                 # default anthropic/claude-haiku-4-5

# ── PostgreSQL ───────────────────────────────────────────────────────────────
# Un solo Postgres aloja el store de Flue (`flue_*`) y el esquema de dominio (`kairos`).
DATABASE_URL=postgresql://user:password@localhost:5432/kairos

# ── Redis ────────────────────────────────────────────────────────────────────
# Cache de market-data + locks (TTL/eviction OK; puede ser tu Redis existente de n8n/Evolution).
REDIS_URL=redis://localhost:6379/0
# Cola/scheduler BullMQ — DEBE ser `noeviction` y persistente (DB/instancia separada).
REDIS_BULLMQ_URL=redis://localhost:6379/1

# ── Binance (vía ccxt) ───────────────────────────────────────────────────────
# Claves de TESTNET de Spot (testnet.binance.vision). Necesarias solo en `testnet`/`live`:
# en `sim` (default) NO se usan — el ejecutor de sim no toca el exchange.
# Para `live`, sustituir por claves de producción con permisos mínimos (sin retiros).
# El sandbox lo decide KAIROS_MODE (ccxt-client.ts: setSandboxMode si mode != live), no una flag aparte.
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ── WhatsApp vía Evolution API (canal de control) ────────────────────────────
EVOLUTION_API_URL=https://evolution.tu-vps.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=kairos
# Secreto compartido para validar la firma del webhook entrante de Evolution.
EVOLUTION_WEBHOOK_SECRET=
# Número (con código de país, p. ej. 573001234567) autorizado a enviar comandos.
WHATSAPP_CONTROL_NUMBER=

# ── Datos fundamentales / sentimiento / on-chain ─────────────────────────────
# Empezar con tiers gratis; el on-chain serio (pago) es opcional y diferible.
# Fuente de noticias del analista fundamental (RSS, sin API key). Default CoinTelegraph.
NEWS_RSS_URL=
LUNARCRUSH_API_KEY=
# GLASSNODE_API_KEY=
# SANTIMENT_API_KEY=
