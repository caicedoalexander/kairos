{
  "name": "kairos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "dev": "flue dev --target node",
    "build": "flue build --target node",
    "start": "node dist/server.mjs",
    "migrate": "node --experimental-strip-types src/db/migrate.ts",
    "seed": "node --experimental-strip-types src/db/seed-strategies.ts",
    "backfill": "node --experimental-strip-types src/lib/market-data/backfill.ts",
    "backtest": "node --experimental-strip-types src/cli/backtest.ts",
    "shadow-report": "node --env-file=.env --experimental-strip-types src/cli/shadow-report.ts",
    "worker": "node --experimental-strip-types src/worker.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@flue/postgres": "^1.0.0-beta.3",
    "@flue/runtime": "^1.0.0-beta.5",
    "bullmq": "^5.79.2",
    "ccxt": "^4.5.60",
    "hono": "^4.12.27",
    "ioredis": "^5.11.1",
    "pg": "^8.22.0",
    "technicalindicators": "^3.1.0",
    "ulidx": "^2.4.1",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@flue/cli": "^1.0.0-beta.5",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv": "^17.4.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
